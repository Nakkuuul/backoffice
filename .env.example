# ── Application ────────────────────────────────────────────
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
APP_NAME=backoffice
LOG_LEVEL=info

# ── Database (PostgreSQL) ──────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=backoffice
DB_USER=backoffice
DB_PASSWORD=change_me
DB_POOL_MAX=10
DB_SSL=false

# ── Auth / Security ────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=1d

# ── CORS ───────────────────────────────────────────────────
CORS_ORIGIN=*

# ── eSign (Digital Signature Certificate via PKCS#11) ──────
# Turn on once the physical DSC token is attached and configured.
ESIGN_ENABLED=false
# Path to the token vendor's PKCS#11 library (.dll on Windows, .so on Linux).
#   SafeNet eToken : C:\Windows\System32\eTPKCS11.dll
#   WatchData      : C:\Windows\System32\Wdpkcs.dll
#   ePass2003      : C:\Windows\System32\eps2003csp11.dll
PKCS11_LIB_PATH=
# PIN fallback — primary source is the encrypted DB value (POST /esign/config/pin).
PKCS11_PIN=
# Optional overrides:
PKCS11_SLOT=
PKCS11_CERT_LABEL=
# Visible signature appearance:
ESIGN_REASON=Digitally signed by broker backoffice
ESIGN_LOCATION=
ESIGN_CONTACT=
# Draw a visible stamp (true) or sign invisibly (false):
ESIGN_VISIBLE=true
# Where to place the stamp:
ESIGN_STAMP_PAGE=first
ESIGN_STAMP_CORNER=bottom-right

# ── email-service (SMTP outbox) ────────────────────────────
EMAIL_FROM=no-reply@yourdomain.com
EMAIL_FROM_NAME=Broker Backoffice
EMAIL_REPLY_TO=
EMAIL_DOMAIN=yourdomain.com
# One-click unsubscribe target for bulk mail (RFC 8058) — strongly recommended.
EMAIL_UNSUBSCRIBE_URL=
# SMTP target — the broker's own Haraka MTA (see mta/README.md).
# On-prem: app runs on the host, MTA container exposes 2525 on localhost.
SMTP_HOST=127.0.0.1
SMTP_PORT=2525
SMTP_SECURE=false
SMTP_USER=relay@yourdomain.com
SMTP_PASS=CHANGE_ME_STRONG_PASSWORD
SMTP_MAX_CONNECTIONS=5
SMTP_MAX_MESSAGES=100
SMTP_RATE_LIMIT=0
SMTP_TLS_REJECT_UNAUTHORIZED=true
# DKIM (run: npm run email:gen-dkim <selector> <domain>):
DKIM_ENABLED=false
DKIM_DOMAIN=
DKIM_SELECTOR=s1
DKIM_PRIVATE_KEY_PATH=
# Outbox worker (disable on API hosts; run a separate fleet at scale):
EMAIL_WORKER_ENABLED=true
EMAIL_WORKER_CONCURRENCY=4
EMAIL_BATCH_SIZE=50
EMAIL_POLL_INTERVAL_MS=1000
EMAIL_MAX_ATTEMPTS=6
# Shared secret the MTA uses to POST inbound mail to /email/inbound (also set
# the same value as `token` in mta/config/inbound_forward.ini).
EMAIL_INBOUND_SECRET=
