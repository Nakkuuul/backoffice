# ── Application ────────────────────────────────────────────
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
APP_NAME=backoffice
LOG_LEVEL=info

# ── Database (PostgreSQL) ──────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=backoffice
DB_USER=backoffice
DB_PASSWORD=change_me
DB_POOL_MAX=10
DB_SSL=false

# ── Auth / Security ────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=1d

# ── CORS ───────────────────────────────────────────────────
CORS_ORIGIN=*
