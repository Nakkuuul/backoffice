# Enabled Haraka plugins (order matters).

# Grant relaying to trusted internal clients (our app submitting on 2525).
local_relay

# Accept RCPT for our own domains (config/host_list) — inbound mail on :25.
rcpt_to.in_host_list

# Forward accepted inbound mail to the app webhook (bounces/complaints/replies).
# Outbound (relayed) mail is left to Haraka core for direct-to-MX delivery.
inbound_forward

