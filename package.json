{
  "name": "backoffice",
  "version": "0.1.0",
  "description": "Broker backoffice — monolithic Node.js application (on-prem deployment)",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "migrate": "node scripts/migrate.js up",
    "migrate:down": "node scripts/migrate.js down",
    "seed": "node scripts/seed.js",
    "test": "node --test tests/**/*.test.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write ."
  },
  "dependencies": {
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.12.0",
    "pino": "^9.3.2",
    "pino-http": "^10.2.0"
  },
  "devDependencies": {
    "eslint": "^9.9.0",
    "pino-pretty": "^11.2.2",
    "prettier": "^3.3.3"
  }
}
